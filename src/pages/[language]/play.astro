---
import {Play, type QuestionSet} from '~components/Play'
import questions from '~data/questions.json'
import {LANG_KEYS} from '~utils'
import Layout from '~layouts/Layout.astro'

export async function getStaticPaths() {
  return LANG_KEYS.map((language) => ({params: {language}}))
}

const {language} = Astro.params

// put the current url language first so it is the default, keep the rest available
const languages = [language!, ...LANG_KEYS.filter((l) => l !== language)]
---

<Layout lang={language} oldBg noFooter>
  <Play
    client:only='react'
    questions={questions as QuestionSet}
    languages={languages}
    languageStorageKey='who-language'
    questionClassName='text-white'
  />
</Layout>
